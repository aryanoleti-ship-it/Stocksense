// LIVE DATA
async function fetchLive(){
  try{
    var allSyms=[...N50,...IDX_SYMS].join(',');
    var url=PROXY+encodeURIComponent('https://query1.finance.yahoo.com/v7/finance/quote?symbols='+allSyms+'&fields=regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,epsTrailingTwelveMonths,dividendYield,beta,regularMarketVolume,fiftyTwoWeekHigh,fiftyTwoWeekLow,shortName');
    var r=await fetch(url);var data=await r.json();
    var results=(data&&data.quoteResponse&&data.quoteResponse.result)||[];
    if(!results.length)throw new Error('No data');
    for(var i=0;i<N50.length;i++){
      var sym=N50[i];
      var q=results.find(function(r){return r.symbol===sym;});
      if(q){liveStocks[sym]={p:Math.round(q.regularMarketPrice*100)/100,c:Math.round(q.regularMarketChange*100)/100,pct:Math.round(q.regularMarketChangePercent*100)/100,mc:fmtCap(q.marketCap),pe:q.trailingPE?q.trailingPE.toFixed(1):'N/A',eps:q.epsTrailingTwelveMonths?q.epsTrailingTwelveMonths.toFixed(2):'N/A',div:q.dividendYield?(q.dividendYield*100).toFixed(2)+'%':'0%',beta:q.beta?q.beta.toFixed(2):'N/A',vol:fmtVol(q.regularMarketVolume),h52:Math.round(q.fiftyTwoWeekHigh||0),l52:Math.round(q.fiftyTwoWeekLow||0),risk:calcRisk(q.beta)};}
    }
    var idxKeys=Object.keys(IDX_MAP);
    for(var j=0;j<idxKeys.length;j++){
      var ys=idxKeys[j];var id=IDX_MAP[ys];
      var q2=results.find(function(r){return r.symbol===ys;});
      if(q2){var idx=INDICES.find(function(i){return i.id===id;});if(idx){idx.v=Math.round(q2.regularMarketPrice||idx.v);idx.c=Math.round((q2.regularMarketChange||idx.c)*10)/10;idx.p=Math.round((q2.regularMarketChangePercent||idx.p)*100)/100;}}
    }
    var sm={};
    for(var k=0;k<N50.length;k++){var s=liveStocks[N50[k]];var meta=NMETA[N50[k]];if(s&&meta){if(!sm[meta.s])sm[meta.s]=[];sm[meta.s].push(s.pct);}}
    for(var l=0;l<SECTORS.length;l++){var sec=SECTORS[l];if(sm[sec.s]&&sm[sec.s].length){sec.c=Math.round(sm[sec.s].reduce(function(a,b){return a+b;},0)/sm[sec.s].length*100)/100;}}
    document.getElementById('ldot').style.background='#16a34a';
    document.getElementById('ltxt').textContent='Live \u00b7 Updated '+new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
    renderHome();
    if(document.getElementById('p-all').style.display!=='none')renderAllStocks();
    if(document.getElementById('p-market').style.display!=='none')renderMarket();
  }catch(e){
    document.getElementById('ldot').style.background='#f59e0b';
    document.getElementById('ltxt').textContent='Using fallback data';
    renderHome();
  }
}
