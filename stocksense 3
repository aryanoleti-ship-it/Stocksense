// AI CHAT
function initChat(){
  if(chatHist.length===0){
    chatHist.push({role:'assistant',content:'Hi! I\'m StockSense AI, powered by Groq. Ask me anything about investing in India \u2014 stocks, mutual funds, Nifty 50, or how to get started. I\'m here to help beginners feel confident!'});
    renderChat();
  }
}
function renderChat(){
  document.getElementById('cm').innerHTML=chatHist.map(function(m){
    if(m.role==='assistant')return '<div class="mrow"><div class="av">AI</div><div class="bai">'+m.content+'</div></div>';
    return '<div class="mrow u"><div class="bu">'+m.content+'</div></div>';
  }).join('');
  var cm=document.getElementById('cm');cm.scrollTop=cm.scrollHeight;
}
async function sc(preset){
  var inp=document.getElementById('ci');
  var msg=preset||inp.value.trim();
  if(!msg)return;
  inp.value='';
  chatHist.push({role:'user',content:msg});
  renderChat();
  document.getElementById('csend').disabled=true;
  document.getElementById('csend').textContent='...';
  try{
    var res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+GROQ},
      body:JSON.stringify({
        model:'llama-3.1-8b-instant',
        messages:[
          {role:'system',content:'You are StockSense AI, a friendly investing assistant for Indian beginners. Keep answers simple, clear, and encouraging. Focus on Indian markets (NSE, BSE, Nifty 50, Sensex). Never give specific buy/sell advice. Always remind users to do their own research. Use simple language a 15-year-old can understand.'},
          ...chatHist
        ],
        max_tokens:400,temperature:0.7
      })
    });
    var data=await res.json();
    var reply=(data.choices&&data.choices[0]&&data.choices[0].message&&data.choices[0].message.content)||'Sorry, I could not get a response. Please try again.';
    chatHist.push({role:'assistant',content:reply});
  }catch(e){
    chatHist.push({role:'assistant',content:'Sorry, there was an error connecting to the AI. Please check your internet connection and try again.'});
  }
  renderChat();
  document.getElementById('csend').disabled=false;
  document.getElementById('csend').textContent='Send \u2192';
}

