// PORTFOLIO
function renderPortfolio(){
  var portVal=port.pos.reduce(function(s,p){var st=liveStocks[p.sym];return s+(st?st.p*p.sh:p.bp*p.sh);},0);
  var invested=port.pos.reduce(function(s,p){return s+p.inv;},0);
  var gl=portVal-invested;
  document.getElementById('pst').innerHTML='<div class="sc"><div class="sl">Cash Available</div><div class="sv">&#8377;'+fmt(port.cash)+'</div></div><div class="sc"><div class="sl">Portfolio Value</div><div class="sv">&#8377;'+fmt(portVal)+'</div></div><div class="sc"><div class="sl">Total Invested</div><div class="sv">&#8377;'+fmt(invested)+'</div></div><div class="sc"><div class="sl">Total Gain/Loss</div><div class="sv" style="color:'+(gl>=0?'#16a34a':'#dc2626')+'">'+(gl>=0?'+':'-')+'&#8377;'+fmt(Math.abs(gl))+'</div></div>';
  if(!port.pos.length){document.getElementById('ptbl').innerHTML='<div style="text-align:center;font-size:12px;color:#9ca3af;padding:36px 0">No positions yet. Add your first stock above!</div>';}
  else{document.getElementById('ptbl').innerHTML=port.pos.map(function(p){var st=liveStocks[p.sym];var cur=st?st.p*p.sh:p.bp*p.sh;var g=cur-p.inv;return '<div class="prow"><span style="font-weight:700;font-size:12px;color:#111">'+p.sym.replace('.NS','')+'</span><span style="font-size:11px;color:#9ca3af">'+(NMETA[p.sym]?NMETA[p.sym].n:p.sym)+'</span><span style="font-size:12px;text-align:right;color:#374151">&#8377;'+fmt(p.inv)+'</span><span style="font-size:12px;text-align:right;color:#374151">&#8377;'+fmt(cur)+'</span><div style="text-align:right"><div style="font-size:11px;color:#6b7280">'+p.sh+' shares</div><div style="font-size:11px;font-weight:700;color:'+(g>=0?'#16a34a':'#dc2626')+'">'+(g>=0?'+':'-')+'&#8377;'+fmt(Math.abs(g))+'</div><button onclick="sellAll(\''+p.sym+'\')" style="font-size:10px;color:#dc2626;background:none;border:none;cursor:pointer;padding:0">Sell All</button></div></div>';}).join('');}
  var colors=['#2d6a5e','#4aa090','#7bc4b8','#a8d8d0','#1a3a35','#3d8a7a'];
  var pd=port.pos.map(function(p,i){return {t:p.sym.replace('.NS',''),v:liveStocks[p.sym]?liveStocks[p.sym].p*p.sh:p.bp*p.sh,c:colors[i%colors.length]};}).filter(function(d){return d.v>0;});
  document.getElementById('palloc').innerHTML=pd.length?pd.map(function(d){return '<div style="display:flex;align-items:center;gap:7px;font-size:11px;margin-bottom:5px"><div style="width:9px;height:9px;border-radius:2px;background:'+d.c+'"></div><span style="font-weight:600;color:#374151">'+d.t+'</span><span style="color:#9ca3af">&#8377;'+fmt(d.v)+'</span></div>';}).join(''):'<div style="font-size:12px;color:#9ca3af;text-align:center;padding:28px 0">Add positions to see allocation</div>';
  if(pChart)pChart.destroy();
  pChart=new Chart(document.getElementById('pc'),{type:'line',data:{labels:port.hist.map(function(h){return h.l;}),datasets:[{data:port.hist.map(function(h){return h.v;}),borderColor:'#2d6a5e',borderWidth:2,fill:true,backgroundColor:'rgba(45,106,94,.15)',pointRadius:0,tension:.4}]},options:{plugins:{legend:{display:false}},scales:{x:{ticks:{font:{size:10}},grid:{display:false}},y:{ticks:{callback:function(v){return 'Rs'+(v/1000).toFixed(0)+'k';},font:{size:10}},grid:{color:'#f0f0f0'}}}}});
}
function ap(){
  var t=document.getElementById('pt').value.trim().toUpperCase()+'.NS';
  var sh=parseInt(document.getElementById('ps').value);
  var err=document.getElementById('pe');
  if(!NMETA[t]){err.textContent='Not found. Try: RELIANCE, TCS, INFY...';return;}
  if(!sh||sh<=0){err.textContent='Enter valid shares.';return;}
  var s=liveStocks[t];var price=s?s.p:1000;var cost=price*sh;
  if(cost>port.cash){err.textContent='Not enough cash. Need Rs'+fmt(cost);return;}
  err.textContent='';port.cash-=cost;
  var ex=port.pos.find(function(p){return p.sym===t;});
  if(ex){ex.sh+=sh;ex.inv+=cost;}else{port.pos.push({sym:t,sh:sh,inv:cost,bp:price});}
  document.getElementById('pt').value='';
  var total=port.cash+port.pos.reduce(function(s,p){var st=liveStocks[p.sym];return s+(st?st.p*p.sh:p.bp*p.sh);},0);
  port.hist.push({l:'T'+port.hist.length,v:Math.round(total)});
  renderPortfolio();
}
function sellAll(sym){
  var p=port.pos.find(function(x){return x.sym===sym;});if(!p)return;
  var s=liveStocks[sym];port.cash+=s?s.p*p.sh:p.bp*p.sh;
  port.pos=port.pos.filter(function(x){return x.sym!==sym;});
  var total=port.cash+port.pos.reduce(function(s,p){var st=liveStocks[p.sym];return s+(st?st.p*p.sh:p.bp*p.sh);},0);
  port.hist.push({l:'T'+port.hist.length,v:Math.round(total)});
  renderPortfolio();
}

