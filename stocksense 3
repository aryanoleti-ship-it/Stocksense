row"><div class="ki"><div class="kl">Market Cap</div><div class="kv">'+s.mc+'</div></div><div class="ki"><div class="kl">P/E Ratio</div><div class="kv">'+s.pe+'</div></div><div class="ki"><div class="kl">EPS</div><div class="kv">'+(s.eps!=='N/A'?'&#8377;'+s.eps:s.eps)+'</div></div><div class="ki"><div class="kl">Dividend</div><div class="kv">'+s.div+'</div></div><div class="ki"><div class="kl">Beta</div><div class="kv">'+s.beta+'</div></div><div class="ki"><div class="kl">Avg Volume</div><div class="kv">'+s.vol+'</div></div><div class="ki"><div class="kl">52W High</div><div class="kv">&#8377;'+fmt(s.h52)+'</div></div><div class="ki"><div class="kl">52W Low</div><div class="kv">&#8377;'+fmt(s.l52)+'</div></div></div></div><div class="card"><div class="stitle">Risk Level</div><div style="display:flex;justify-content:space-between;font-size:10px;color:#9ca3af;margin-bottom:3px"><span>Low</span><span>Medium</span><span>High</span></div><div class="rbar"><div class="rfill" style="width:'+riskPct+'%;background:'+riskColor+'"></div></div><div style="font-size:11px;font-weight:700;margin-top:3px;color:'+riskColor+'">'+s.risk+' Risk</div></div>';
